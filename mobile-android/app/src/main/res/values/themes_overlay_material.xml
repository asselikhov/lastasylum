<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Только для ContextThemeWrapper при создании FAB оверлея (не меняет тему всего приложения). -->
    <style name="Theme.LastAsylum.OverlayMaterial" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="colorPrimary">#9B7CFF</item>
        <item name="colorOnPrimary">#1A1024</item>
        <item name="colorPrimaryContainer">#3A2F55</item>
        <item name="colorOnPrimaryContainer">#EDE7FF</item>
        <item name="colorSurfaceContainerHigh">#2A2538</item>
    </style>

    <!-- Хост для системного пикера из оверлея: непрозрачный фон, пока чат-панель скрыта (без «просвечивания» игры). -->
    <style name="Theme.LastAsylum.OverlayDialog" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:windowBackground">#FF10141E</item>
        <item name="android:statusBarColor">#FF10141E</item>
        <item name="android:navigationBarColor">#FF10141E</item>
        <item name="android:windowIsTranslucent">false</item>
        <item name="android:windowIsFloating">false</item>
        <item name="android:backgroundDimEnabled">false</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowNoTitle">true</item>
    </style>

    <!-- NoDisplay relay: copy clip + schedule deep link without showing system bars. -->
    <style name="Theme.LastAsylum.GameBridge" parent="@android:style/Theme.NoDisplay" />
</resources>
