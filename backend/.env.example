PORT=3000
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB_NAME=last_asylum
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=replace_with_a_second_long_random_secret
JWT_REFRESH_EXPIRES_IN=30d

# Sideloaded Android APK: when versionCode here is greater than the installed app, the client offers an update (open downloadUrl in browser).
ANDROID_APK_VERSION_CODE=2
ANDROID_APK_DOWNLOAD_URL=

# SMTP (password reset). If SMTP_HOST is empty, mail is logged via jsonTransport (dev/CI only).
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@example.com
# Optional: used in reset email subject
APP_PUBLIC_NAME=SquadRelay

# Comma-separated origins for HTTP CORS and Socket.IO; leave empty for * (dev only).
ALLOWED_ORIGINS=

# Cloudflare R2 (S3-compatible storage) for chat image attachments
# Create a bucket and API token in Cloudflare → R2.
# Endpoint format: https://<ACCOUNT_ID>.r2.cloudflarestorage.com
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
# Optional (usually keep as auto for R2)
R2_REGION=auto

# Optional: helps Cloudflare R2 with newer @aws-sdk transitive deps (also set in code / early import).
# AWS_REQUEST_CHECKSUM_CALCULATION=WHEN_REQUIRED
# AWS_RESPONSE_CHECKSUM_VALIDATION=WHEN_REQUIRED

# Optional: Firebase service account JSON (single line) for FCM push when new chat messages are created.
# If unset, push delivery is skipped; clients can still register device tokens.
FIREBASE_SERVICE_ACCOUNT_JSON=
